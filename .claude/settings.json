{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Auto-formatting (rustfmt)",
            "command": "{ f=$(jq -r '.tool_input.file_path // empty'); [ -z \"$f\" ] && exit 0; case \"$f\" in *.rs) for p in rustfmt \"$HOME/.cargo/bin/rustfmt\" /opt/homebrew/opt/rustup/bin/rustfmt /usr/local/opt/rustup/bin/rustfmt; do if command -v \"$p\" >/dev/null 2>&1; then \"$p\" --edition 2024 \"$f\"; break; fi; done;; esac; } 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo xtask:*)",
      "Bash(cargo run --package xtask:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(scripts/bootstrap-worktree.sh)"
    ]
  }
}
